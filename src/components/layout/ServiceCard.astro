---
interface Props {
  name: string;
  icon: string;
  desc: string;
  link: string;
  color: string;
}

const { name, icon, desc, link, color } = Astro.props;
---

<a 
  href={link} 
  class="block bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-md transition p-6 hover:-translate-y-1"
>
  <div class={`w-14 h-14 rounded-2xl bg-gradient-to-br ${color} flex items-center justify-center text-2xl mb-4`}>
    {icon}
  </div>
  <h3 class="font-bold text-lg text-slate-800 mb-2">
    {name}
  </h3>
  <p class="text-slate-500 text-sm">
    {desc}
  </p>
  <span class="inline-flex items-center gap-1 mt-4 text-blue-600 text-sm font-medium">
    Jelajahi →
  </span>
</a>
