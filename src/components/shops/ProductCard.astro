---
import { formatRupiah } from '../../utils/format.js';
import { createWaLink } from '../../utils/whatsapp.js';

interface Product {
  id: number;
  slug: string;
  nama: string;
  harga_asli?: number;
  harga_diskon: number;
  foto: string;
  kategori: string[];
  rating?: number;
  terjual?: number;
  stok?: number;
}

const { product } = Astro.props as { product: Product };
const discount = product.harga_asli 
  ? Math.round((1 - product.harga_diskon / product.harga_asli) * 100) 
  : null;
---

<div class="card group">
  <!-- Image -->
  <a href={`/shops/${product.slug}`} class="block relative overflow-hidden">
    <img 
      src={product.foto} 
      alt={product.nama}
      class="w-full h-48 object-cover group-hover:scale-105 transition duration-300"
      loading="lazy"
    />
    
    {/* Badges */}
    <div class="absolute top-3 left-3 flex flex-col gap-2">
      {discount && discount >= 50 && (
        <span class="bg-red-500 text-white text-xs font-bold px-2 py-1 rounded-full">
          -{discount}%
        </span>
      )}
      {product.stok && product.stok <= 5 && (
        <span class="bg-orange-500 text-white text-xs font-bold px-2 py-1 rounded-full">
          Stok Menipis!
        </span>
      )}
    </div>
  </a>

  {/* Content */}
  <div class="p-4">    {/* Category */}
    <div class="flex gap-1 mb-2">
      {product.kategori?.slice(0, 2).map(cat => (
        <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded-full">
          {cat}
        </span>
      ))}
    </div>

    {/* Title */}
    <a href={`/shops/${product.slug}`} class="block">
      <h3 class="font-medium text-slate-800 line-clamp-2 hover:text-primary transition mb-2">
        {product.nama}
      </h3>
    </a>

    {/* Rating + Sold */}
    {(product.rating || product.terjual) && (
      <div class="flex items-center gap-3 text-xs text-slate-500 mb-3">
        {product.rating && <span>⭐ {product.rating}</span>}
        {product.terjual && <span>📦 {product.terjual} terjual</span>}
      </div>
    )}

    {/* Price */}
    <div class="flex items-baseline gap-2 mb-4">
      <span class="font-bold text-primary text-lg">
        {formatRupiah(product.harga_diskon)}
      </span>
      {product.harga_asli && (
        <span class="text-slate-400 text-sm line-through">
          {formatRupiah(product.harga_asli)}
        </span>
      )}
    </div>

    {/* Buttons */}
    <div class="flex gap-2">
      <a 
        href={`/shops/${product.slug}`}
        class="flex-1 btn-outline text-center text-sm py-2"
      >
        Detail
      </a>
      <a 
        href={createWaLink('shops', product)}
        target="_blank"
        class="flex-1 btn-primary text-center text-sm py-2"
      >
        💬 Beli      </a>
    </div>
  </div>
</div>
