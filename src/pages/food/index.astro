---
import Layout from '../../layouts/Layout.astro';
import food from '../../data/food.json';
import { formatRupiah } from '../../utils/format.js';
import { createWaLink } from '../../utils/whatsapp.js';
---

<Layout title="MJ Food - Kuliner Lokal Sukabumi">
  <section class="py-8 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-heading font-bold text-slate-800 mb-2">
          🍜 MJ Food
        </h1>
        <p class="text-slate-600">Kuliner lezat khas Parungkuda, siap antar ke rumahmu!</p>
      </div>

      {/* Menu Grid */}
      <div class="space-y-4">
        {food.map(item => (
          <div class="card p-4 flex gap-4">
            <img 
              src={item.foto} 
              alt={item.nama}
              class="w-24 h-24 object-cover rounded-lg"
            />
            <div class="flex-1">
              <h3 class="font-semibold text-slate-800 mb-1">{item.nama}</h3>
              <p class="text-sm text-slate-500 mb-2 line-clamp-2">{item.deskripsi}</p>
              <div class="flex items-center justify-between">
                <span class="font-bold text-primary">{formatRupiah(item.harga)}</span>
                <a 
                  href={createWaLink('food', item)}
                  target="_blank"
                  class="btn-primary text-sm py-2 px-4"
                >
                  🛒 Pesan
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
