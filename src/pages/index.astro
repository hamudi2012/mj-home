---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/layout/ServiceCard.astro';
import ProductCard from '../components/shops/ProductCard.astro';
import shops from '../data/shops.json';

const services = [
  {
    name: "MJ Shops",
    icon: "🛍️",
    desc: "Fashion & produk fisik harga sahabat",
    link: "/mj-home/shops",
    color: "from-pink-500 to-rose-500"
  },
  {
    name: "MJ Food",
    icon: "🍜",
    desc: "Kuliner lokal Parungkuda & Sukabumi",
    link: "/food",
    color: "from-orange-500 to-amber-500"
  },
  {
    name: "MJ Studio",
    icon: "🎨",
    desc: "Jasa foto, video & desain kreatif",
    link: "/studio",
    color: "from-purple-500 to-indigo-500"
  },
  {
    name: "MJ News",
    icon: "📰",
    desc: "Berita & info terbaru Sukabumi",
    link: "/news",
    color: "from-blue-500 to-cyan-500"
  },
  {
    name: "MJ Loker",
    icon: "💼",
    desc: "Lowongan kerja lokal terpercaya",
    link: "/loker",
    color: "from-emerald-500 to-teal-500"
  },
  {
    name: "MJ Ojex",
    icon: "🛵",
    desc: "Layanan antar cepat area Parungkuda",
    link: "/ojex",
    color: "from-red-500 to-orange-500"
  }
];
const featuredProducts = shops.slice(0, 4);
---

<Layout title="MJ Home - Portal Layanan Lokal Sukabumi">
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-primary to-slate-900 text-white py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-heading font-bold mb-4">
        Selamat Datang di <span class="text-secondary">MJ Home</span>
      </h1>
      <p class="text-lg text-slate-300 mb-8">
        Satu portal untuk semua kebutuhan lokal Parungkuda & Sukabumi
      </p>
      
      <!-- Quick Search -->
      <div class="max-w-md mx-auto relative">
        <input 
          type="text" 
          placeholder="Cari produk, makanan, atau info..." 
          class="w-full px-5 py-4 rounded-xl text-slate-900 focus:outline-none focus:ring-2 focus:ring-secondary shadow-lg"
        />
        <button class="absolute right-2 top-1/2 -translate-y-1/2 bg-secondary text-white px-4 py-2 rounded-lg font-medium hover:bg-secondary/90 transition">
          🔍
        </button>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-12 px-4 bg-slate-50">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl font-heading font-bold text-center mb-8 text-slate-800">
        Layanan Kami
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(service => (
          <ServiceCard {...service} />
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Products -->
  <section class="py-12 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-heading font-bold text-slate-800">
          🔥 Sedang Trending di MJ Shops
        </h2>        <a href="/shops" class="text-primary font-medium hover:underline">
          Lihat Semua →
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {featuredProducts.map(product => (
          <ProductCard product={product} />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 px-4 bg-primary text-white">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-2xl font-heading font-bold mb-4">
        Butuh Bantuan atau Punya Pertanyaan?
      </h2>
      <p class="text-slate-300 mb-6">
        Tim kami siap membantu via WhatsApp. Respon cepat, ramah, dan solutif!
      </p>
      <a 
        href="https://wa.me/6281234567890" 
        target="_blank"
        class="inline-flex items-center gap-2 bg-white text-primary font-bold px-6 py-3 rounded-xl hover:bg-slate-100 transition"
      >
        💬 Chat Admin Sekarang
      </a>
    </div>
  </section>
</Layout>
