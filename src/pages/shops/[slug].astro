---
import Layout from '../../layouts/Layout.astro';
import shops from '../../data/shops.json';

export function getStaticPaths() {
  return shops.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;

function formatRupiah(amount) {
  return new Intl.NumberFormat('id-ID', {
    style: 'currency',
    currency: 'IDR',
    minimumFractionDigits: 0,
  }).format(amount);
}
---

<Layout title={product.nama}>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <!-- Breadcrumb -->
    <nav class="mb-6">
      <a href="/mj-home/shops" class="text-blue-600 hover:underline">
        ← Kembali ke Shops
      </a>
    </nav>

    <!-- Product Detail -->
    <div class="grid md:grid-cols-2 gap-8">
      <!-- Image -->
      <div>
        <img 
          src={product.foto} 
          alt={product.nama}
          class="w-full rounded-2xl shadow-lg"
        />
      </div>

      <!-- Info -->
      <div class="space-y-4">
        <h1 class="text-3xl font-bold text-slate-800">{product.nama}</h1>
        
        <!-- Price -->
        <div class="space-y-2">
          <div class="text-3xl font-bold text-blue-600">
            {formatRupiah(product.harga_diskon)}
          </div>
          {product.harga_asli && (
            <div class="text-slate-400 line-through">
              {formatRupiah(product.harga_asli)}
            </div>
          )}
        </div>

        <!-- Description -->
        <div>
          <h3 class="font-semibold text-slate-800 mb-2">Deskripsi</h3>
          <p class="text-slate-600">{product.deskripsi}</p>
        </div>

        <!-- Stock -->
        {product.stok && (
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-green-500"></span>
            <span class="text-slate-600">Stok: {product.stok} pcs</span>
          </div>
        )}

        <!-- CTA Button -->
        <a 
          href={`https://wa.me/6281234567890?text=Halo%20saya%20mau%20order%20${encodeURIComponent(product.nama)}`}
          target="_blank"
          class="block bg-green-500 hover:bg-green-600 text-white font-bold text-center py-4 rounded-xl transition"
        >
          💬 Order via WhatsApp
        </a>
      </div>
    </div>
  </div>
</Layout>
