---
import Layout from '../../layouts/Layout.astro';
import { formatRupiah } from '../../utils/format.js';
import { createWaLink } from '../../utils/whatsapp.js';
import shops from '../../data/shops.json';

export async function getStaticPaths() {
  return shops.map(product => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const discount = product.harga_asli 
  ? Math.round((1 - product.harga_diskon / product.harga_asli) * 100) 
  : null;
---

<Layout title={product.nama} description={product.deskripsi} image={product.foto}>
  <section class="py-8 px-4">
    <div class="max-w-4xl mx-auto">
      <!-- Breadcrumb -->
      <nav class="text-sm text-slate-500 mb-6">
        <a href="/" class="hover:text-primary">Home</a> 
        <span class="mx-2">/</span>
        <a href="/shops" class="hover:text-primary">Shops</a> 
        <span class="mx-2">/</span>
        <span class="text-slate-800">{product.nama}</span>
      </nav>

      <!-- Product Detail -->
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Image -->
        <div class="card overflow-hidden">
          <img 
            src={product.foto} 
            alt={product.nama}
            class="w-full h-80 md:h-96 object-cover"
          />
        </div>

        <!-- Info -->
        <div>
          {/* Badges */}
          <div class="flex gap-2 mb-4">
            {discount && discount >= 50 && (
              <span class="bg-red-500 text-white text-sm font-bold px-3 py-1 rounded-full">
                Diskon {discount}%
              </span>            )}
            {product.stok && product.stok <= 5 && (
              <span class="bg-orange-500 text-white text-sm font-bold px-3 py-1 rounded-full">
                Stok Menipis!
              </span>
            )}
          </div>

          {/* Title */}
          <h1 class="text-2xl font-heading font-bold text-slate-800 mb-3">
            {product.nama}
          </h1>

          {/* Rating + Sold */}
          {(product.rating || product.terjual) && (
            <div class="flex items-center gap-4 text-sm text-slate-600 mb-4">
              {product.rating && <span class="flex items-center gap-1">⭐ {product.rating} (4.9)</span>}
              {product.terjual && <span>📦 {product.terjual} terjual</span>}
            </div>
          )}

          {/* Price */}
          <div class="flex items-baseline gap-3 mb-6">
            <span class="text-3xl font-bold text-primary">
              {formatRupiah(product.harga_diskon)}
            </span>
            {product.harga_asli && (
              <span class="text-slate-400 text-lg line-through">
                {formatRupiah(product.harga_asli)}
              </span>
            )}
          </div>

          {/* Description */}
          <div class="prose prose-sm text-slate-600 mb-6">
            <p>{product.deskripsi}</p>
          </div>

          {/* Variants */}
          {(product.ukuran?.length || product.warna?.length) && (
            <div class="mb-6">
              {product.ukuran?.length > 0 && (
                <div class="mb-4">
                  <label class="block text-sm font-medium text-slate-700 mb-2">Ukuran:</label>
                  <div class="flex flex-wrap gap-2">
                    {product.ukuran.map(size => (
                      <button class="px-4 py-2 border border-slate-200 rounded-lg text-sm hover:border-primary hover:text-primary transition">
                        {size}
                      </button>
                    ))}                  </div>
                </div>
              )}
              {product.warna?.length > 0 && (
                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2">Warna:</label>
                  <div class="flex flex-wrap gap-2">
                    {product.warna.map(color => (
                      <button class="px-4 py-2 border border-slate-200 rounded-lg text-sm hover:border-primary hover:text-primary transition">
                        {color}
                      </button>
                    ))}
                  </div>
                </div>
              )}
            </div>
          )}

          {/* CTA Buttons */}
          <div class="flex flex-col sm:flex-row gap-3">
            <a 
              href={createWaLink('shops', product)}
              target="_blank"
              class="flex-1 btn-primary text-center py-3 font-semibold"
            >
              💬 Pesan via WhatsApp
            </a>
            <button class="flex-1 btn-outline py-3 font-semibold">
              ♡ Tambah ke Wishlist
            </button>
          </div>

          {/* Trust Badges */}
          <div class="grid grid-cols-3 gap-4 mt-8 pt-6 border-t">
            <div class="text-center">
              <div class="text-2xl mb-1">🚚</div>
              <div class="text-xs text-slate-500">Free Ongkir*</div>
            </div>
            <div class="text-center">
              <div class="text-2xl mb-1">✅</div>
              <div class="text-xs text-slate-500">Garansi Bahan</div>
            </div>
            <div class="text-center">
              <div class="text-2xl mb-1">💬</div>
              <div class="text-xs text-slate-500">Respon Cepat</div>
            </div>
          </div>
        </div>
      </div>
    </div>  </section>
</Layout>
