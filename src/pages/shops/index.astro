---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/shops/ProductCard.astro';
import shops from '../../data/shops.json';

const categories = [...new Set(shops.flatMap(p => p.kategori))];
---

<Layout title="MJ Shops - Fashion Murah Sukabumi">
  <section class="py-8 px-4 bg-slate-50">
    <div class="max-w-6xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-8">
        <h1 class="text-3xl font-heading font-bold text-slate-800 mb-2">
          🛍️ MJ Shops
        </h1>
        <p class="text-slate-600">Fashion premium harga sahabat, pengiriman area Sukabumi</p>
      </div>

      <!-- Filters -->
      <div class="flex flex-wrap gap-2 mb-6 justify-center">
        <button class="filter-btn active px-4 py-2 rounded-full bg-primary text-white text-sm font-medium">
          Semua
        </button>
        {categories.map(cat => (
          <button 
            class="filter-btn px-4 py-2 rounded-full bg-white border border-slate-200 text-slate-600 text-sm font-medium hover:border-primary hover:text-primary transition"
            data-filter={cat}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Product Grid -->
      <div id="product-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {shops.map(product => (
          <ProductCard product={product} />
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  // Simple client-side filter
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      // Remove active class from all
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active', 'bg-primary', 'text-white'));
      // Add active to clicked
      e.currentTarget.classList.add('active', 'bg-primary', 'text-white');
      
      const filter = e.currentTarget.dataset.filter;
      const cards = document.querySelectorAll('#product-grid > div');
      
      cards.forEach(card => {
        if (!filter || card.innerHTML.toLowerCase().includes(filter.toLowerCase())) {
          card.style.display = 'block';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>
